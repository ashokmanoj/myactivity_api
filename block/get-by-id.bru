meta {
  name: Get Block By ID
  type: http
  seq: 2
}
get {
  url: {{base_url}}/api/v1/block/{{block_id}}
  body: none
  auth: none
}
headers {
  Content-Type: application/json
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("has blockId", function() { expect(res.getBody().data).to.have.property("blockId"); });
  test("has district", function() { expect(res.getBody().data).to.have.property("district"); });
}