meta {
  name: Update Block
  type: http
  seq: 4
}
put {
  url: {{base_url}}/api/v1/block/{{block_id}}
  body: json
  auth: none
}
headers {
  Content-Type: application/json
}
body:json {
  {
    "blockName": "JORHAT EAST UPDATED"
  }
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("updated", function() { expect(res.getBody().message).to.include("updated"); });
}