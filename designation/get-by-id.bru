meta {
  name: Get Designation By ID
  type: http
  seq: 2
}
get {
  url: {{base_url}}/api/v1/designation/{{designation_id}}
  body: none
  auth: none
}
headers {
  Content-Type: application/json
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("has designationId", function() { expect(res.getBody().data).to.have.property("designationId"); });
  test("has project", function() { expect(res.getBody().data).to.have.property("project"); });
}