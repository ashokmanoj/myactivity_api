meta {
  name: Sync Districts (Bulk)
  type: http
  seq: 6
}
post {
  url: {{base_url}}/api/v1/district/sync
  body: json
  auth: none
}
headers {
  Content-Type: application/json
}
body:json {
  {
    "districts": [
      { "districtName": "JORHAT",    "stateCode": "AS" },
