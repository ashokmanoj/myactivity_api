      { "districtName": "DIBRUGARH", "stateCode": "AS" }
    ]
  }
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("3 synced", function() { expect(res.getBody().results.synced.length).to.equal(3); });
}