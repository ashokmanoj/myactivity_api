meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{base_url}}/health
  body: none
  auth: none
}

headers {
  Content-Type: application/json
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("API is running", function() {
    expect(res.getBody().status).to.equal('OK');
  });
  test("Has timestamp", function() {
    expect(res.getBody().timestamp).to.be.a('string');
  });
}
