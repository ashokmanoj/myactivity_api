meta {
  name: Delete Project
  type: http
  seq: 5
}
delete {
  url: {{base_url}}/api/v1/project/{{project_id}}
  body: none
  auth: none
}
headers {
  Content-Type: application/json
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("deleted", function() { expect(res.getBody().message).to.include("deleted"); });
  test("isActive is 0", function() { expect(res.getBody().data.isActive).to.equal(0); });
}