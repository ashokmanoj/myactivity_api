meta {
  name: Update Project
  type: http
  seq: 4
}
put {
  url: {{base_url}}/api/v1/project/{{project_id}}
  body: json
  auth: none
}
headers {
  Content-Type: application/json
}
body:json {
  {
    "projectName": "ICT Program 2025 Updated",
    "endDate": "2026-12-31"
  }
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("updated", function() { expect(res.getBody().message).to.include("updated"); });
}