meta {
  name: Get User Information By ID
  type: http
  seq: 2
}
get {
  url: {{base_url}}/api/v1/user-information/{{user_info_id}}
  body: none
  auth: none
}
headers {
  Content-Type: application/json
}
tests {
  test("Status 200", function() { expect(res.getStatus()).to.equal(200); });
  test("has userInfoId", function() { expect(res.getBody().data).to.have.property("userInfoId"); });
  test("has user relation", function() { expect(res.getBody().data).to.have.property("user"); });
}